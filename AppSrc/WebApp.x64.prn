37771>>>
37771>>>            Case (NavigateData.eNavigateType = nfFromMain)
37774>>>                // If from main, this is a probably a main-file lookup from a Zoom
37774>>>                WebSet pbRender of oDetailButton to False
37775>>>                Case Break
37776>>>
37776>>>            Case Else // must be nfUndefined
37776>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37776>>>
37776>>>        Case End
37776>>>
37776>>>    End_Procedure
37777>>>
